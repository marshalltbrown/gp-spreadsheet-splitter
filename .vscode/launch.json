{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Spreadsheet Splitter",
      "program": "${workspaceFolder}/index.js",
      "args": ["source", "output"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "install dependencies",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
